<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="20dp"
    app:cardElevation="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tituloEditarAlimento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Editar Alimento"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:text="Nombre"
                android:textColor="@color/BotonesImagenesDietas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18dp"/>

            <EditText
                android:id="@+id/editNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:backgroundTint="@color/white"
                android:inputType="textCapSentences"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:text="Calorías (kcal)"
                android:textColor="@color/BotonesImagenesDietas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18dp"/>
            <EditText
                android:id="@+id/editCalorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:backgroundTint="@color/white"
                android:inputType="numberDecimal"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:text="Proteínas (g)"
                android:textColor="@color/BotonesImagenesDietas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18dp"/>
            <EditText
                android:id="@+id/editProteinas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:backgroundTint="@color/white"
                android:inputType="numberDecimal"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:text="Carbohidratos (g)"
                android:textColor="@color/BotonesImagenesDietas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18dp"/>
            <EditText
                android:id="@+id/editCarbos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:backgroundTint="@color/white"
                android:inputType="numberDecimal"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:text="Grasas (g)"
                android:textColor="@color/BotonesImagenesDietas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18dp"/>
            <EditText
                android:id="@+id/editGrasas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:backgroundTint="@color/white"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/botonCancelarEditar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancelar"
                    android:textColor="@color/white"
                    android:backgroundTint="@android:color/transparent"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/botonGuardarEditar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guardar"
                    android:textColor="@color/black"
                    android:backgroundTint="@color/BotonesImagenesDietas"/>
            </LinearLayout>

        </LinearLayout>
</androidx.cardview.widget.CardView>

