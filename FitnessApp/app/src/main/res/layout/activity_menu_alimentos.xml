<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentacion.menu.Dietas.MenuAlimentosActivity"
    android:background="@color/fondoPantalla">

    <TextView
        android:id="@+id/tituloAlimentos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alimentos"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.03"/>

    <ImageButton
        android:id="@+id/botonVolverActividad"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_flecha_atras"
        app:layout_constraintVertical_bias="0.023"
        app:layout_constraintHorizontal_bias="0.07"/>

    <ImageButton
        android:id="@+id/botonCrearAlimento"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_crear"
        app:layout_constraintVertical_bias="0.023"
        app:layout_constraintHorizontal_bias="0.87"/>

    <Button
        android:id="@+id/botonDesplegarMisAlimentos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" ▼ Mis Alimentos Personalizados"
        android:textColor="@color/white"
        android:backgroundTint="@color/fondoContenedor"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:gravity="start|center_vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tituloAlimentos"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMisAlimentos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="#1E1E1E"
        app:layout_constraintTop_toBottomOf="@+id/botonDesplegarMisAlimentos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:itemCount="3"
        tools:listitem="@layout/spinner_no_desplegado"/>

    <Button
        android:id="@+id/botonBuscarAlimento"
        android:layout_width="67dp"
        android:layout_height="wrap_content"
        android:text="🔍"
        android:textSize="18dp"
        android:backgroundTint="@color/fondoPantalla"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/recyclerMisAlimentos"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.044"
        android:layout_marginStart="5dp"/>

    <EditText
        android:id="@+id/buscadorAlimentos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="70dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp"
        android:hint="Buscar Alimento"
        android:inputType="text"
        android:textColor="@color/white"
        android:textColorHint="@color/pistaEditables"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/recyclerMisAlimentos"
        app:layout_constraintVertical_bias="0.03"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAlimentos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/buscadorAlimentos"
        app:layout_constraintBottom_toBottomOf="parent" />



</androidx.constraintlayout.widget.ConstraintLayout>