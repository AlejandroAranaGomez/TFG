<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/fondoPopUp"
    app:cardCornerRadius="20dp"
    app:cardElevation="90dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tituloBorrarAlimento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eliminar Alimento"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/preguntaBorrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Deseas borrar el alimento ...?"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <Button
                android:id="@+id/botonCancelarBorrar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancelar"
                android:textColor="@color/white"
                android:backgroundTint="@android:color/transparent"/>

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/botonConfirmarBorrar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Si, borrar"
                android:textColor="@color/black"
                android:backgroundTint="@color/BotonesImagenesDietas"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>