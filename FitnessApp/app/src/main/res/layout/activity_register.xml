<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <ScrollView
        android:id="@+id/mainRegister"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".RegisterActivity"
        app:layout_constraintBottom_toBottomOf="@id/botonVolverInicio">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FDFBFB"
            android:foregroundTint="#FAFAFA"
            android:gravity="right"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear Nueva Cuenta"
                android:textColor="#FAFBF8"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Campos del formulario -->
            <EditText
                android:id="@+id/editNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Nombre"
                android:inputType="textPersonName"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <EditText
                android:id="@+id/editApellido1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Primer Apellido"
                android:inputType="textPersonName"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <EditText
                android:id="@+id/editApellido2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Segundo Apellido"
                android:inputType="textPersonName"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <EditText
                android:id="@+id/editContrasenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <EditText
                android:id="@+id/editTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Teléfono"
                android:inputType="phone"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <EditText
                android:id="@+id/editFechaNacimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Fecha Nacimiento (YYYY-MM-DD)"
                android:inputType="date"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <Spinner
                android:id="@+id/spinnerGenero"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:textColorHint="#757474"
                android:inputType="textCapCharacters" />

            <EditText
                android:id="@+id/editPeso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Peso (ej. 70.5)"
                android:inputType="numberDecimal"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <EditText
                android:id="@+id/editAltura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Altura (ej. 1.75)"
                android:inputType="numberDecimal"
                android:textColorHint="#757474"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/botonRegistrar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="#96EF2D"
                android:text="Confirmar Registro"
                android:textColor="#000000"
                android:textSize="18dp" />

        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/botonVolverInicio"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="29dp"
        android:layout_marginTop="50dp"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_flecha_atras"/>

</androidx.constraintlayout.widget.ConstraintLayout>