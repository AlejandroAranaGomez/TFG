<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondoPantalla">

    <TextView
        android:id="@+id/tituloDietas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mis Dietas"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.03"/>

    <Button
        android:id="@+id/botonInformacionAlimentos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Informacion Alimentos"
        android:textColor="@color/black"
        android:textSize="18dp"
        android:backgroundTint="@color/BotonesImagenes"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tituloDietas"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintVertical_bias="0.83"/>


</androidx.constraintlayout.widget.ConstraintLayout>