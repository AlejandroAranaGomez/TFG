<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondoPantalla">



    <TextView
        android:id="@+id/tituloDietas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mis Dietas"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.03"/>

    <ImageButton
        android:id="@+id/botonCrearDieta"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_crear"
        app:layout_constraintVertical_bias="0.023"
        app:layout_constraintHorizontal_bias="0.87"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDietas"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tituloDietas"
        app:layout_constraintBottom_toTopOf="@+id/botonInformacionAlimentos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDias"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="5dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toBottomOf="@+id/recyclerDietas"
        app:layout_constraintBottom_toTopOf="@+id/botonInformacionAlimentos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerComidas"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="40dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toBottomOf="@+id/recyclerDias"
        app:layout_constraintBottom_toTopOf="@+id/botonInformacionAlimentos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0"/>

    <TextView
        android:id="@+id/nombreDia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NombreDia"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@+id/recyclerDias"
        app:layout_constraintBottom_toTopOf="@+id/botonInformacionAlimentos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.02"
        app:layout_constraintVertical_bias="0.05"
        android:visibility="gone"/>

    <Button
        android:id="@+id/botonEditarDia"
        android:layout_width="wrap_content"
        android:layout_height="35dp"
        app:layout_constraintTop_toBottomOf="@+id/recyclerDias"
        app:layout_constraintBottom_toTopOf="@+id/botonInformacionAlimentos"
        app:layout_constraintStart_toEndOf="@id/nombreDia"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Cambiar nombre"
        android:textSize="12dp"
        android:backgroundTint="@color/editar"
        android:layout_marginStart="5dp"
        app:layout_constraintHorizontal_bias="0.02"
        app:layout_constraintVertical_bias="0.015"
        android:visibility="gone"/>

    <Button
        android:id="@+id/botonBorrarDia"
        android:layout_width="62dp"
        android:layout_height="35dp"
        app:layout_constraintTop_toBottomOf="@+id/recyclerDias"
        app:layout_constraintBottom_toTopOf="@+id/botonInformacionAlimentos"
        app:layout_constraintStart_toEndOf="@id/botonEditarDia"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="🗑️"
        android:textSize="12dp"
        android:backgroundTint="@color/borrar"
        app:layout_constraintHorizontal_bias="0.98"
        app:layout_constraintVertical_bias="0.015"
        android:visibility="gone"/>

    <Button
        android:id="@+id/botonInformacionAlimentos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Informacion Alimentos"
        android:textColor="@color/black"
        android:textSize="18dp"
        android:backgroundTint="@color/BotonesImagenesDietas"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tituloDietas"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintVertical_bias="0.83"/>




</androidx.constraintlayout.widget.ConstraintLayout>