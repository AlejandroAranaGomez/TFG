<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/fondoPopUp">

    <TextView
        android:id="@+id/tituloPopUpEjercicio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre ejercicio"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/musculoPopUp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Músculo principal"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tituloPopUpEjercicio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <FrameLayout
        android:id="@+id/contenedorImagen"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/musculoPopUp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imagenEjercicio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>

        <ImageButton
            android:id="@+id/botonAnterior"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="8dp"
            android:background="@drawable/ic_flecha_atras" />

        <ImageButton
            android:id="@+id/botonSiguiente"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="8dp"
            android:background="@drawable/ic_flecha_alante" />

    </FrameLayout>


    <Button
        android:id="@+id/botonCerrarPopup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cerrar"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/BotonesImagenesRutinas"
        app:layout_constraintTop_toBottomOf="@id/contenedorImagen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
