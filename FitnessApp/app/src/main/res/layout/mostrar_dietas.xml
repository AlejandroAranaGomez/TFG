<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="240dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    android:backgroundTint="@color/fondoContenedor"
    app:cardBackgroundColor="@color/white">

    <FrameLayout
        android:id="@+id/contenedorGiratorio"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/layoutFrente"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:id="@+id/nombreDieta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dieta Volumen"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center_horizontal"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/caloriasDieta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2500 kcal"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textos"/>

                <Space
                    android:layout_width="40dp"
                    android:layout_height="40dp"/>

                <TextView
                    android:id="@+id/textoEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVA"
                    android:textColor="@color/textos"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:columnCount="3">

                <TextView
                    android:id="@+id/proteinas"
                    android:text="Prote 180g"
                    android:textSize="12dp"
                    android:textColor="@color/textos"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/carbohidratos"
                    android:text="Carb 300g"
                    android:textSize="12dp"
                    android:textColor="@color/textos"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/grasas"
                    android:text="Grasas 80g"
                    android:textColor="@color/textos"
                    android:textSize="12dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="4dp"/>

            </GridLayout>

            <Button
                android:id="@+id/botonVerPlanDieta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🗓️ Ver Plan Semanal"
                android:textColor="@color/BotonesImagenesDietas"
                android:backgroundTint="@color/white"
                android:layout_marginEnd="5dp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pulsa para ver la descripcion"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/botonEditarDieta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Editar"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/editar"
                    android:layout_marginEnd="5dp"
                    android:layout_marginTop="4dp"/>

                <Button
                    android:id="@+id/botonBorrarDieta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Borrar"
                    android:textColor="@color/white"
                    android:layout_marginStart="5dp"
                    android:backgroundTint="@color/borrar"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutAtras"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@color/fondoContenedor"
            android:padding="8dp">

            <TextView
                android:id="@+id/nombreDietaAtras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dieta Volumen"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center_horizontal"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/textoDescripcionCompleta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción detallada..."
                android:textColor="@color/white"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>