<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:background="@color/fondoPantalla"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageButton
        android:id="@+id/botonVolverActividad"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_flecha_atras"
        app:layout_constraintVertical_bias="0.01"
        app:layout_constraintHorizontal_bias="0.05"/>

    <TextView
        android:id="@+id/tituloIngredienteSeleccionado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el alimento"
        android:textColor="@color/textos"
        android:textStyle="bold"
        android:textSize="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="11dp"/>

    <Button
        android:id="@+id/botonDesplegarMisAlimentos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" ▼ Mis Alimentos Personalizados"
        android:textColor="@color/white"
        android:backgroundTint="@color/fondoContenedor"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:gravity="start|center_vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/botonVolverActividad"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMisAlimentos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="#1E1E1E"
        app:layout_constraintTop_toBottomOf="@+id/botonDesplegarMisAlimentos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:itemCount="3"
        tools:listitem="@layout/spinner_no_desplegado"/>

    <EditText
        android:id="@+id/buscadorAlimentos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Buscar alimento"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/botonBuscarAlimento"
        app:layout_constraintTop_toBottomOf="@id/recyclerMisAlimentos"
        android:textColor="@color/white"
        android:textColorHint="@color/pistaEditables"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/botonBuscarAlimento"
        android:layout_width="67dp"
        android:layout_height="wrap_content"
        android:text="🔍"
        android:textSize="18dp"
        android:backgroundTint="@color/fondoPantalla"
        app:layout_constraintStart_toEndOf="@id/buscadorAlimentos"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/buscadorAlimentos"
        app:layout_constraintBottom_toBottomOf="@id/buscadorAlimentos"
        app:layout_constraintVertical_bias="0.044"
        android:layout_marginStart="5dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAlimentos"
        android:layout_width="0dp"
        android:layout_height="200dp"
        app:layout_constraintTop_toBottomOf="@id/buscadorAlimentos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_max="200dp"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tituloCantidadeSeleccionado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleccione la cantidad en gramos"
        android:textColor="@color/textos"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/recyclerAlimentos"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/editCantidad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Cantidad en gramos"
        android:textColorHint="@color/pistaEditables"
        android:textColor="@color/white"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/tituloCantidadeSeleccionado"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/textPropiedades"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Kcal: 0 | P: 0 | C: 0 | G: 0"
        android:textColor="@color/textosExplicacion"
        app:layout_constraintTop_toBottomOf="@id/editCantidad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/botonAgregar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Agregar"
        app:layout_constraintTop_toBottomOf="@id/textPropiedades"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/BotonesImagenesDietas"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>



